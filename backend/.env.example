APP_NAME=ButaKeando API
APP_ENV=development
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
WEB_CONCURRENCY=1
FRONTEND_URL=http://127.0.0.1:5173
FRONTEND_SUCCESS_PATH=/pedido/confirmado
FRONTEND_CANCEL_PATH=/checkout
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173
SERVE_FRONTEND=false
FRONTEND_DIST_PATH=../frontend/dist
DATABASE_URL=sqlite:///./butakeando.db
AUTO_CREATE_TABLES=true
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
STRIPE_SECRET_KEY=replace-with-your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=replace-with-your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=replace-with-your-stripe-webhook-secret
STRIPE_API_VERSION=2026-02-25.clover
STRIPE_CURRENCY=eur
ORDER_NOTIFICATION_EMAIL=owner@butakeando.test
EMAIL_FROM=orders@butakeando.test
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true
SMTP_SSL=false
SMTP_TIMEOUT_SECONDS=10
LOG_LEVEL=INFO
